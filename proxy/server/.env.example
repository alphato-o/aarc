# AARC standalone proxy — environment. Copy to .env on the VPS and fill in.
# .env is gitignored; NEVER commit real keys. Real env vars override .env.
# These mirror the Cloudflare Worker secrets (proxy/.dev.vars.example).

# ---- HTTP ----
# Port the node:http server listens on (Caddy reverse-proxies to this).
PORT=8787

# ---- LLM provider (set exactly ONE key) ----
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
# Override the OpenRouter API base (e.g. a Concessionaire gateway
# https://<host>/openrouter/v1). Default: openrouter.ai.
# OPENROUTER_BASE_URL=https://ai.dreamydreams.xyz/openrouter/v1

# Alternative: Anthropic native instead of OpenRouter.
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ---- Per-purpose model overrides (optional; Sonnet defaults otherwise) ----
# NOTE: the legacy bare OPENROUTER_MODEL / ANTHROPIC_MODEL are deliberately
# ignored by the handlers — only the per-purpose names below are consulted.
# OPENROUTER_MODEL_SCRIPT=anthropic/claude-sonnet-4.5
# OPENROUTER_MODEL_REPLY=anthropic/claude-sonnet-4.5
# OPENROUTER_MODEL_SUMMARY=anthropic/claude-sonnet-4.5
# ANTHROPIC_MODEL_SCRIPT=claude-sonnet-4-6
# ANTHROPIC_MODEL_REPLY=claude-sonnet-4-6
# ANTHROPIC_MODEL_SUMMARY=claude-sonnet-4-6

# ---- TTS ----
ELEVENLABS_API_KEY=REPLACE_ME
# Override the ElevenLabs API base (e.g. a Concessionaire gateway
# https://<host>/elevenlabs/v1). Default: api.elevenlabs.io.
# ELEVENLABS_BASE_URL=https://ai.dreamydreams.xyz/elevenlabs/v1

# ---- Auth / observability (used if/when wired in the handlers) ----
# Shared device token the iOS app sends to authenticate against the proxy.
# DEVICE_TOKEN=REPLACE_ME
# Sentry DSN placeholder for error reporting.
# SENTRY_DSN=https://REPLACE_ME@oXXXX.ingest.sentry.io/XXXXXXX
